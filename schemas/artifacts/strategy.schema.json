{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Shipwright Strategy Artifact",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "mode",
    "depth",
    "metadata",
    "decision_frame",
    "unknowns",
    "pass_fail_readiness",
    "evidence",
    "payload"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "artifact_type": { "type": "string", "enum": ["strategy"] },
    "mode": { "type": "string", "enum": ["fast", "rigorous"] },
    "depth": { "type": "string", "enum": ["quick", "light", "standard", "deep"] },
    "metadata": {
      "type": "object",
      "required": ["title", "status", "authors", "updated_at"],
      "properties": {
        "title": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["draft", "in-review", "approved", "exploratory-draft"]
        },
        "authors": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "updated_at": { "type": "string" }
      }
    },
    "decision_frame": {
      "type": "object",
      "required": ["recommendation", "tradeoff", "confidence", "owner", "decision_date"],
      "properties": {
        "recommendation": { "type": "string" },
        "tradeoff": { "type": "string" },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "owner": { "type": "string" },
        "decision_date": { "type": "string" },
        "revisit_trigger": { "type": "string" },
        "hypothesis": { "type": "boolean" },
        "assumption": { "type": "boolean" }
      }
    },
    "unknowns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pass_fail_readiness": {
      "type": "object",
      "required": ["status", "reason"],
      "properties": {
        "status": { "type": "string", "enum": ["PASS", "FAIL"] },
        "reason": { "type": "string" }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidence_id", "kind", "source_ref", "confidence", "supports"],
        "properties": {
          "evidence_id": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["metric", "interview", "research", "experiment", "document", "assumption"]
          },
          "source_ref": { "type": "string" },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
          "supports": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    },
    "challenge_resolution": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["finding_id", "state", "note"],
        "properties": {
          "finding_id": { "type": "string" },
          "state": { "type": "string", "enum": ["resolved", "waived", "deferred"] },
          "note": { "type": "string" },
          "waiver_reason": { "type": "string" },
          "owner": { "type": "string" }
        }
      }
    },
    "payload": {
      "type": "object",
      "required": [
        "vision",
        "context",
        "bets",
        "boundaries",
        "review_cadence",
        "primary_segment"
      ],
      "properties": {
        "vision": { "type": "string" },
        "context": {
          "type": "object",
          "required": ["current_state"],
          "properties": {
            "current_state": {
              "type": "object",
              "required": ["product_stage"],
              "properties": {
                "product_stage": { "type": "string" }
              }
            }
          }
        },
        "primary_segment": { "type": "string" },
        "bets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "bet_id",
              "name",
              "thesis",
              "assumptions",
              "investment_level",
              "success_metric",
              "kill_criteria",
              "evidence_ids"
            ],
            "properties": {
              "bet_id": { "type": "string" },
              "name": { "type": "string" },
              "thesis": { "type": "string" },
              "assumptions": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              },
              "investment_level": { "type": "string" },
              "success_metric": {
                "type": "object",
                "required": ["metric_id", "name", "unit", "timeframe"],
                "properties": {
                  "metric_id": { "type": "string" },
                  "name": { "type": "string" },
                  "segment": { "type": "string" },
                  "unit": { "type": "string" },
                  "timeframe": { "type": "string" },
                  "baseline": { "type": ["number", "string"] },
                  "target": { "type": ["number", "string"] },
                  "explanation": { "type": "string" }
                }
              },
              "kill_criteria": { "type": "string" },
              "evidence_ids": {
                "type": "array",
                "items": { "type": "string" }
              },
              "hypothesis": { "type": "boolean" },
              "assumption": { "type": "boolean" }
            }
          }
        },
        "boundaries": {
          "type": "object",
          "required": ["not_doing"],
          "properties": {
            "not_doing": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "review_cadence": {
          "type": "object",
          "required": ["weekly", "monthly", "quarterly"],
          "properties": {
            "weekly": { "type": "string" },
            "monthly": { "type": "string" },
            "quarterly": { "type": "string" }
          }
        }
      }
    }
  }
}
