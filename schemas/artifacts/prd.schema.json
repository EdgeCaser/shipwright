{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Shipwright PRD Artifact",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "mode",
    "depth",
    "metadata",
    "decision_frame",
    "unknowns",
    "pass_fail_readiness",
    "evidence",
    "payload"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "artifact_type": { "type": "string", "enum": ["prd"] },
    "mode": { "type": "string", "enum": ["fast", "rigorous"] },
    "depth": { "type": "string", "enum": ["quick", "light", "standard", "deep"] },
    "metadata": {
      "type": "object",
      "required": ["title", "status", "authors", "updated_at"],
      "properties": {
        "title": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["draft", "in-review", "approved", "exploratory-draft"]
        },
        "authors": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "updated_at": { "type": "string" }
      }
    },
    "decision_frame": {
      "type": "object",
      "required": ["recommendation", "tradeoff", "confidence", "owner", "decision_date"],
      "properties": {
        "recommendation": { "type": "string" },
        "tradeoff": { "type": "string" },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "owner": { "type": "string" },
        "decision_date": { "type": "string" },
        "revisit_trigger": { "type": "string" },
        "hypothesis": { "type": "boolean" },
        "assumption": { "type": "boolean" }
      }
    },
    "unknowns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pass_fail_readiness": {
      "type": "object",
      "required": ["status", "reason"],
      "properties": {
        "status": { "type": "string", "enum": ["PASS", "FAIL"] },
        "reason": { "type": "string" }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidence_id", "kind", "source_ref", "confidence", "supports"],
        "properties": {
          "evidence_id": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["metric", "interview", "research", "experiment", "document", "assumption"]
          },
          "source_ref": { "type": "string" },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
          "supports": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    },
    "challenge_resolution": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["finding_id", "state", "note"],
        "properties": {
          "finding_id": { "type": "string" },
          "state": { "type": "string", "enum": ["resolved", "waived", "deferred"] },
          "note": { "type": "string" },
          "waiver_reason": { "type": "string" },
          "owner": { "type": "string" }
        }
      }
    },
    "payload": {
      "type": "object",
      "required": [
        "problem_statement",
        "customer_evidence_ids",
        "success_metrics",
        "scope",
        "open_questions",
        "target_segment"
      ],
      "properties": {
        "problem_statement": {
          "type": "object",
          "required": ["problem_id", "text"],
          "properties": {
            "problem_id": { "type": "string" },
            "text": { "type": "string" },
            "hypothesis": { "type": "boolean" },
            "assumption": { "type": "boolean" }
          }
        },
        "customer_evidence_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "success_metrics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["metric_id", "name", "unit", "timeframe", "evidence_ids"],
            "properties": {
              "metric_id": { "type": "string" },
              "name": { "type": "string" },
              "segment": { "type": "string" },
              "unit": { "type": "string" },
              "timeframe": { "type": "string" },
              "baseline": { "type": ["number", "string"] },
              "target": { "type": ["number", "string"] },
              "evidence_ids": {
                "type": "array",
                "items": { "type": "string" }
              },
              "hypothesis": { "type": "boolean" },
              "assumption": { "type": "boolean" },
              "explanation": { "type": "string" }
            }
          }
        },
        "scope": {
          "type": "object",
          "required": ["in", "out"],
          "properties": {
            "in": {
              "type": "array",
              "items": { "type": "string" }
            },
            "out": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "open_questions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "target_segment": { "type": "string" }
      }
    }
  }
}
