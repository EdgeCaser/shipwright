SLACK_APP_TOKEN=xapp-...         # App-Level Token for Socket Mode
SLACK_BOT_TOKEN=xoxb-...         # Bot token for posting messages (Web API)
SLACK_BOT_USER_ID=U0123456789    # Bot's user ID (to strip from mentions)
CLAUDE_PATH=claude               # Path to claude CLI if not in PATH
CLAUDE_TIMEOUT_MS=120000         # CLI timeout in milliseconds
PROJECT_CWD=/path/to/project     # Directory Claude runs in (project context)
STATE_PATH=/path/to/state.json   # Optional path for persistent local state
ALLOWED_CHANNELS=C12345,C67890   # Optional comma-separated channel IDs
ALLOWED_USERS=U12345,U67890      # Optional comma-separated Slack user IDs
MAX_QUEUE_SIZE=20                # Optional queue cap before rejecting new work
SLACK_CONTEXT_MESSAGES=8         # Optional thread-context window
MAX_REPLY_CHARS=3000             # Optional Slack reply chunk size
READ_ONLY_MODE=true              # Recommended: true
ALLOWED_COMMANDS=status,question,summarize,draft,help  # Optional command allowlist
