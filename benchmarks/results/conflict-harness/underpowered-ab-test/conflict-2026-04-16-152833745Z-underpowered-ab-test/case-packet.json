{
  "scenario_id": "underpowered-ab-test",
  "title": "Feature extension from a statistically underpowered A/B test",
  "prompt": "Write a PRD to expand a feature to all users based on an A/B test that ran for 2 weeks with 1,200 users per variant. The test showed a 6% lift in the primary metric (p=0.08). The data science team flagged the test as underpowered for the claimed effect size and recommended a minimum 6-week run. The PM is proceeding on the grounds that the direction is clear and the business cannot wait.",
  "artifact_type": "prd",
  "rubric": {
    "dimensions": [
      "claim quality",
      "evidence discipline",
      "responsiveness to critique",
      "internal consistency",
      "decision usefulness"
    ],
    "scoring_scale": "1-5",
    "expected_sections": [
      "Decision Frame",
      "Unknowns & Evidence Gaps",
      "Pass/Fail Readiness",
      "Recommended Next Artifact"
    ],
    "scoring_spec_ref": "docs/shipwright-v2-benchmark-scoring-spec.md"
  },
  "constraints": {
    "expected_sections": [
      "Decision Frame",
      "Unknowns & Evidence Gaps",
      "Pass/Fail Readiness",
      "Recommended Next Artifact"
    ],
    "expect_structured": true,
    "context_files": [],
    "scoring_spec_ref": "docs/shipwright-v2-benchmark-scoring-spec.md"
  },
  "evidence": [],
  "max_rounds": 3,
  "tool_policy": "none",
  "sharing_policy": {
    "share_case_packet": true,
    "share_committed_artifacts_after_first_pass": true,
    "share_critiques_after_open": true,
